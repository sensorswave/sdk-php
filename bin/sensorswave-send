#!/usr/bin/env php
<?php

/**
 * sensorswave-send — 事件投递定时任务
 *
 * 从 EventQueue 中读取已入队的埋点事件，批量投递到数据接收端。
 * 建议通过 cron 定时执行，例如每分钟一次：
 *   * * * * * /path/to/sensorswave-send https://your-endpoint.com your-source-token
 *
 * 下方使用默认 Config（本地文件队列、默认日志）。
 * 生产环境请根据实际需求自定义，例如：
 *
 *   $config = new Config(
 *       logger:             $psrLogger,           // 自定义 PSR-3 Logger
 *       eventQueue:         new RedisEventQueue($redis),  // Redis 队列替代本地文件
 *       flushIntervalMs:    5_000,                // 刷新间隔（毫秒）
 *       httpConcurrency:    4,                    // 并发投递数
 *       httpTimeoutMs:      5_000,                // HTTP 超时（毫秒）
 *       httpRetry:          3,                    // 失败重试次数
 *       onTrackFailHandler: function (array $batch, Throwable $e) {
 *           // 投递失败回调
 *       },
 *   );
 */

declare(strict_types=1);

require dirname(__DIR__) . '/vendor/autoload.php';

use SensorsWave\Config\Config;
use SensorsWave\Worker\SendCommand;

$endpoint = $argv[1] ?? '';
$sourceToken = $argv[2] ?? '';

if ($endpoint === '' || $sourceToken === '') {
    fwrite(STDERR, "Usage: sensorswave-send <endpoint> <sourceToken>\n");
    exit(1);
}

$command = new SendCommand(
    $endpoint,
    $sourceToken,
    new Config()
);

exit($command->run());
