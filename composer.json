{
  "name": "sensorswave/sdk-php",
  "description": "SensorsWave PHP SDK",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5",
    "phpstan/phpstan": "^2.1"
  },
  "autoload": {
    "psr-4": {
      "SensorsWave\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SensorsWave\\Tests\\": "tests/"
    }
  },
  "bin": [
    "bin/sensorswave-sync",
    "bin/sensorswave-send"
  ],
  "scripts": {
    "test": "phpunit",
    "phpstan": "phpstan analyse"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
